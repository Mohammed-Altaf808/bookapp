<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Book</title>
</head>
<body>
    <h1>Add A Book</h1>
    <form action="/books/<%=books._id%>?_method=PUT" method="post">
        <label for="title">Title: </label>
        <input type="text" id="title" name="title" placeholder="Title of the book" value="<%=books.title%>">
        
        <label for="author">Author: </label>
        <input type="text" id="author" name="author" placeholder="Author of the book" value="<%=books.author%>">
        
        <label for="genre">Genre: </label>
        <input type="text" id="genre" name="genre" placeholder="Genre of the book" value="<%=books.genre%>">
        
        <label for="description">Description: </label>
        <input type="text" id="description" name="description" placeholder="Description" value="<%=books.description%>">
        
        <button type="submit">Edit Book</button>
    </form>
    <a href="/books/<%=books._id%>" >Cancel</a>
</body>
</html>
